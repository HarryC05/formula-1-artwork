{
  "name": "formula-1-artwork-generator",
  "version": "1.0.0",
  "description": "Generate Formula 1 race weekend artwork from CSV data",
  "main": "generate.js",
  "scripts": {
    "setup-flags": "node setup-flags.js",
    "extract-flags": "node extract-flags.js",
    "generate": "node generate.js",
    "test": "node generate.js --csv example.csv",
    "upload": "node upload-to-sportsdb.js",
    "upload:dry-run": "node upload-to-sportsdb.js --dry-run",
    "upload:visible": "node upload-to-sportsdb.js --headless=false",
    "upload:verbose": "node upload-to-sportsdb.js --verbose",
    "trackmaps": "node download-upload-trackmaps.js --csv 2026.csv",
    "trackmaps:download": "node download-upload-trackmaps.js --csv 2026.csv --download-only",
    "trackmaps:upload": "node download-upload-trackmaps.js --csv 2026.csv --upload-only",
    "trackmaps:dry-run": "node download-upload-trackmaps.js --csv 2026.csv --dry-run",
    "trackmaps:visible": "node download-upload-trackmaps.js --csv 2026.csv --headless=false",
    "trackmaps:verbose": "node download-upload-trackmaps.js --csv 2026.csv --verbose"
  },
  "keywords": [
    "formula1",
    "f1",
    "artwork",
    "svg",
    "generator"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "commander": "^12.0.0",
    "csv-parser": "^3.0.0",
    "dotenv": "^17.3.1",
    "jsdom": "^24.0.0",
    "playwright": "^1.58.2",
    "sharp": "^0.33.0",
    "svg-path-properties": "^2.0.2"
  }
}
